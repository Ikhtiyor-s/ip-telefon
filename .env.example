# =============================================================================
# AUTODIALER PRO - PRODUCTION SOZLAMALARI (NAMUNA)
# =============================================================================
# Bu faylni .env.production ga nusxa qiling va haqiqiy qiymatlarni yozing

# NONBOR API
NONBOR_BASE_URL=https://prod.nonbor.uz/api/v2
NONBOR_SECRET=your-secret-here

# TELEGRAM
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ASTERISK AMI
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=autodialer
AMI_PASSWORD=<KUCHLI_AMI_PAROL>

# SIP TRUNK (Sarkor / Well-Tech)
SIP_USERNAME=<SIP_LOGIN>
SIP_PASSWORD=<SIP_PAROL>

# API XAVFSIZLIK
API_SECRET_KEY=your-api-secret-key-here

# SKIP_ASTERISK=false - Production da Asterisk to'liq ishlaydi
SKIP_ASTERISK=false

# Audio (Production - Linux path)
ASTERISK_SOUNDS_PATH=/app/audio
ASTERISK_PLAYBACK_PATH=/var/lib/asterisk/sounds/autodialer/cache
PLATFORM=linux

# CORS (vergul bilan ajratilgan) — production da HTTPS ishlatilishi kerak
CORS_ORIGINS=https://admin.yourdomain.com

# QO'NG'IROQ YOZUVLARI (call recording)
# Asterisk MixMonitor fayllarini saqlash katalogi (Asterisk server ichida)
CALL_RECORD_DIR=/var/spool/asterisk/recording
# Bu API serverning tashqi URL manzili (recording URL uchun)
API_BASE_URL=https://api.yourdomain.com

# ADMIN.NONBOR CALL WEBHOOK
# admin.nonbor ga qo'ng'iroq ma'lumotlari yuboriladigan URL
# (bo'sh qoldirilsa webhook yuborilmaydi)
CALL_REPORT_URL=

# VAQTLAR (sekundda)
WAIT_BEFORE_CALL=90
TELEGRAM_ALERT_TIME=180
MAX_CALL_ATTEMPTS=2
RETRY_INTERVAL=30

# REJA BUYURTMA VAQTLARI (daqiqada)
PLANNED_REMINDER_TIME=60
PLANNED_GROUP_ALERT_TIME=60
