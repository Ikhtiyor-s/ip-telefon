# =============================================================================
# AUTODIALER PRO - PRODUCTION SOZLAMALARI (NAMUNA)
# =============================================================================
# Bu faylni .env.production ga nusxa qiling va haqiqiy qiymatlarni yozing

# NONBOR API
NONBOR_BASE_URL=https://prod.nonbor.uz/api/v2
NONBOR_SECRET=your-nonbor-secret-here

# TELEGRAM
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ASTERISK AMI — Docker ichida servis nomi "asterisk"
AMI_HOST=asterisk
AMI_PORT=5038
AMI_USERNAME=autodialer
AMI_PASSWORD=<KUCHLI_AMI_PAROL>

# SIP TRUNK (Sarkor / Well-Tech)
SIP_USERNAME=<SIP_LOGIN>
SIP_PASSWORD=<SIP_PAROL>

# API XAVFSIZLIK — bo'sh qoldirmang! (bo'sh = hamma kirishi mumkin)
API_SECRET_KEY=<KAMIDA_32_BELGILI_TASODIFIY_KALIT>

# NONBOR POLLING (true=polling, false=faqat webhook)
# Nonbor webhook yubora olsa false qo'ying — API load kamayadi
NONBOR_POLLING_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# NONBOR WEBHOOK (kiruvchi)
# ─────────────────────────────────────────────────────────────────────────────
# Nonbor admin panelida webhook sozlamasida ko'rsatilgan SECRET KEY ni yozing.
# Nonbor har bir webhook so'roviga quyidagi headerlarni qo'shadi:
#   X-Webhook-Signature: sha256=<imzo>   ← HMAC-SHA256 imzo
#   X-Webhook-Timestamp: <unix_seconds>  ← So'rov vaqti (Unix timestamp, soniyada)
#
# HMAC hisoblash formati (Nonbor standarti):
#   message  = "{X-Webhook-Timestamp}.{raw_body}"
#   imzo     = "sha256=" + HMAC_SHA256(INBOUND_WEBHOOK_SECRET, message)
#
# Qayerdan olish:
#   Nonbor admin panel → Integratsiyalar → Webhook → Secret Key
#   (NONBOR_SECRET bilan bir xil bo'lishi ham mumkin — nonbor admindan aniqlang)
#
# URL: POST https://autodialer.yourdomain.com/webhook/inbound
# Test:  GET https://autodialer.yourdomain.com/webhook/inbound/ping
INBOUND_WEBHOOK_SECRET=<NONBOR_ADMIN_PANELIDAN_SECRET_KEY>

# SKIP_ASTERISK=false - Production da Asterisk to'liq ishlaydi
SKIP_ASTERISK=false

# Audio — Docker volume orqali ikkala konteyner ulashadi
ASTERISK_SOUNDS_PATH=/app/audio
ASTERISK_PLAYBACK_PATH=/var/lib/asterisk/sounds/autodialer/cache
PLATFORM=linux

# CORS — production da o'z domeningizni yozing
CORS_ORIGINS=https://admin.nonbor.uz

# QO'NG'IROQ YOZUVLARI
# Docker volume "call-recordings":
#   Asterisk:   /var/spool/asterisk/recording  (yozadi)
#   Autodialer: /app/recordings                (o'qiydi, API orqali uzatadi)
CALL_RECORD_DIR=/app/recordings
# API server tashqi manzili — recording URL uchun
API_BASE_URL=https://autodialer.yourdomain.com

# ADMIN.NONBOR WEBHOOK (ichki kanal — SSRF tekshiruvisiz)
# Docker network ichida: http://admin-panel-service:PORT/endpoint
# Tashqi URL bo'lsa ham ishlaydi: https://admin.nonbor.uz/api/call-reports
CALL_REPORT_URL=http://admin-panel:8088/api/autodialer/call-reports

# ADMIN PANEL URL (guruh sinxronlash uchun)
ADMIN_PANEL_URL=http://admin-panel:8088

# ASTERISK WEBHOOK LISTENER (Asterisk serverida ishlaydigan listener)
# Bo'sh qolsa — to'g'ridan-to'g'ri AMI ishlatiladi
# Asterisk server: scripts/asterisk_webhook_listener.py
AUTODIALER_NOTIFY_URL=http://172.29.124.85:5000/notify
# Webhook listener uchun secret (listener dagi WEBHOOK_SECRET bilan bir xil bo'lsin)
WEBHOOK_SECRET=nonbor-secret-key

# NONBOR API HEALTH MONITORING (qo'ng'iroq orqali)
# API ishlamasa adminga telefon qilinadi (Telegram emas, qo'ng'iroq)
# Sozlamalar admin-call/config API orqali ham o'zgartiriladi
# api_health_enabled: true/false — monitoring yoq/o'chiq
# api_health_check_interval: 600 — normal holatda har necha soniyada tekshirish (default: 10 daqiqa)
# api_health_check_interval_down: 60 — API o'chiq bo'lganda har necha soniyada (tiklandi aniqlash)
# api_health_call_interval: 300 — API o'chiq bo'lganda har necha soniyada qayta qo'ng'iroq
# api_health_timeout: 10 — HTTP timeout soniyada
# api_health_language: uz/ru — qo'ng'iroq tili
# Telegram alert: TELEGRAM_BOT_TOKEN va TELEGRAM_CHAT_ID to'g'ri bo'lsa avtomatik ishlaydi

# VAQTLAR (sekundda)
WAIT_BEFORE_CALL=90
TELEGRAM_ALERT_TIME=180
MAX_CALL_ATTEMPTS=2
RETRY_INTERVAL=30

# REJA BUYURTMA VAQTLARI (daqiqada)
PLANNED_REMINDER_TIME=60
PLANNED_GROUP_ALERT_TIME=60
